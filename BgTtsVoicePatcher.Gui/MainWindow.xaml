<Window x:Class="BgTtsVoicePatcher.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BgTtsVoicePatcher.Gui.ViewModels"
        Title="BgTtsVoicePatcher" Height="880" Width="1050" MinHeight="700" MinWidth="900">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="4,2" />
            <Setter Property="Padding" Value="3" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="4,2" />
            <Setter Property="Padding" Value="3" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="4,2" />
            <Setter Property="Padding" Value="10,4" />
        </Style>
        <Style TargetType="Label">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="4,4" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="Expander">
            <Setter Property="Margin" Value="0,4" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Margin" Value="4" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="True" />
            <Setter Property="CanUserDeleteRows" Value="True" />
            <Setter Property="RowHeaderWidth" Value="0" />
        </Style>
        <Style TargetType="DataGridCell">
            <Style.Triggers>
                <Trigger Property="IsReadOnly" Value="True">
                    <Setter Property="Background" Value="#F5F5F5" />
                    <Setter Property="Foreground" Value="#777777" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="180" />
        </Grid.RowDefinitions>

        <!-- ===================== Wizard tabs ===================== -->
        <TabControl Grid.Row="0" SelectedIndex="{Binding CurrentStepIndex}" Margin="0,0,0,8">

            <!-- Step 1: Game, TLK, DLG and CRE -->
            <TabItem Header="1. Directories">
                <StackPanel Margin="10">
                    <GroupBox Header="Game directory">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="Game directory" />
                            <TextBox Grid.Column="1" Text="{Binding GameDir, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Root of your game install, containing 'override' and 'lang' folders." />
                            <Button Grid.Column="2" Content="Browse..." Command="{Binding BrowseGameDirCommand}" />
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="dialog.tlk">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Content="Found TLK files" />
                                <ComboBox Grid.Column="1" ItemsSource="{Binding DiscoveredTlkFiles}"
                                          SelectedItem="{Binding SelectedTlkPath}" />
                                <Button Grid.Column="2" Content="Rescan" Command="{Binding ScanForTlkCommand}" />
                                <Button Grid.Column="3" Content="Browse manually..." Command="{Binding BrowseTlkCommand}" />
                            </Grid>
                            <TextBlock Margin="4,8,4,0" TextWrapping="Wrap" Foreground="Gray"
                                       Text="Scans '&lt;game-dir&gt;\lang\*\dialog.tlk' automatically after you pick a game directory. If your install uses a non-standard layout, use Browse manually." />
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Reinstall / Uninstall" Visibility="{Binding IsManifestPresent, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="4,0,4,6"
                                       Text="A previous run's manifest was found beside this dialog.tlk. Reinstall re-applies its SoundResRef entries (e.g. after a game patch overwrote dialog.tlk) without re-synthesizing audio. Uninstall removes them, restoring dialog.tlk to its unpatched state. Neither deletes your generated .wav/.ogg files." />
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Reinstall" Command="{Binding RepatchCommand}" Background="#2E7D32" Foreground="White" />
                                <Button Content="Uninstall" Command="{Binding UnpatchCommand}" Background="#C62828" Foreground="White" />
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Speaker / gender resolution (recommended: Near Infinity mass-export)">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="DLG folder" />
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding DlgDir, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Optional. Near Infinity mass-export of .dlg files. Defaults to the override folder." />
                            <Button Grid.Row="0" Grid.Column="2" Content="Browse..." Command="{Binding BrowseDlgDirCommand}" />

                            <Label Grid.Row="1" Grid.Column="0" Content="CRE folder" />
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CreDir, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Optional. Near Infinity mass-export of .cre files. Enables automatic male/female detection." />
                            <Button Grid.Row="1" Grid.Column="2" Content="Browse..." Command="{Binding BrowseCreDirCommand}" />

                            <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" TextWrapping="Wrap" Foreground="Gray" Margin="4,4,4,0"
                                       Text="Tip: In Near Infinity, press Ctrl+M (Tools -&gt; Mass Export), select DLG (and separately CRE), uncheck 'Decompile scripts and dialogs', and export each to its own folder." />
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Encoding">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="Encoding" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableEncodings}"
                                      SelectedItem="{Binding SelectedEncoding}"
                                      DisplayMemberPath="DisplayName">
                            </ComboBox>
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </TabItem>

            <!-- Step 2: Config -->
            <TabItem Header="2. Config">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <GroupBox Header="patcher-config.json">
                            <StackPanel>
                                <TextBlock Text="{Binding ConfigStatusText}" TextWrapping="Wrap" Foreground="Gray" Margin="4,0,4,6" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Label Grid.Column="0" Content="Config file" />
                                    <TextBox Grid.Column="1" Text="{Binding ConfigPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" />
                                    <Button Grid.Column="2" Content="Browse..." Command="{Binding BrowseConfigCommand}" />
                                    <Button Grid.Column="3" Content="Reload" Command="{Binding ReloadConfigCommand}" />
                                </Grid>

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Label Grid.Row="0" Grid.Column="0" Content="PC name" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding PcName, UpdateSourceTrigger=PropertyChanged}"
                                             HorizontalAlignment="Left" Width="200"
                                             ToolTip="Replaces &lt;CHARNAME&gt; and &lt;GABBER&gt; tokens in dialogue." />

                                    <Label Grid.Row="1" Grid.Column="0" Content="PC race" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding PcRace, UpdateSourceTrigger=PropertyChanged}"
                                             HorizontalAlignment="Left" Width="200"
                                             ToolTip="Replaces &lt;RACE&gt; and &lt;PRO_RACE&gt; tokens." />

                                    <Label Grid.Row="2" Grid.Column="0" Content="PC gender" />
                                    <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding PcGenderOptions}"
                                              SelectedItem="{Binding PcGender}" HorizontalAlignment="Left" Width="200"
                                              ToolTip="Which side of gender-sensitive tokens (&lt;PRO_HESHE&gt; etc.) is used." />
                                </Grid>

                                <Button Content="Save Config" Command="{Binding SaveConfigCommand}" HorizontalAlignment="Left" Margin="4,10,4,4"
                                        Background="#1565C0" Foreground="White" />
                            </StackPanel>
                        </GroupBox>

                        <Expander Header="CRE name replacements (DLG system name -&gt; CRE basename)">
                            <DataGrid ItemsSource="{Binding CreNameReplacementsRows}" MaxHeight="220">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="DLG system name" Binding="{Binding Key}" Width="*" />
                                    <DataGridTextColumn Header="CRE basename" Binding="{Binding Value}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Expander>

                        <Expander Header="Gender overrides (system name -&gt; forced gender)">
                            <DataGrid ItemsSource="{Binding GenderOverridesRows}" MaxHeight="220">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="System name" Binding="{Binding Key}" Width="*" />
                                    <DataGridComboBoxColumn Header="Gender" SelectedItemBinding="{Binding Value}"
                                                             ItemsSource="{x:Static vm:MainViewModel.SpeakerGenderOptions}"
                                                             Width="100" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Expander>

                        <Expander Header="Gender tokens (male / female / neutral replacement words)">
                            <DataGrid ItemsSource="{Binding GenderTokenRows}" MaxHeight="260">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Token" Binding="{Binding Token}" Width="*" />
                                    <DataGridTextColumn Header="Male" Binding="{Binding Male}" Width="*" />
                                    <DataGridTextColumn Header="Female" Binding="{Binding Female}" Width="*" />
                                    <DataGridTextColumn Header="Neutral" Binding="{Binding Neutral}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Expander>

                        <Expander Header="Identity tokens (replaced by PC name/race)">
                            <DataGrid ItemsSource="{Binding IdentityTokenRows}" MaxHeight="180">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Token" Binding="{Binding Value}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Expander>

                        <Expander Header="Phonetic rules (regex find/replace, applied last)">
                            <DataGrid ItemsSource="{Binding PhoneticRuleRows}" MaxHeight="220">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Pattern (regex)" Binding="{Binding Pattern}" Width="*" />
                                    <DataGridTextColumn Header="Replacement" Binding="{Binding Replacement}" Width="*" />
                                    <DataGridTextColumn Header="Comment" Binding="{Binding Comment}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Step 3: Speaker Review -->
            <TabItem Header="3. Speaker Review" Height="20" VerticalAlignment="Top">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- ================================================================ -->
                    <!-- Comprehensive Help & Requirements Section                         -->
                    <!-- ================================================================ -->
                    <Expander Grid.Row="0" Margin="0,0,0,10" IsExpanded="False" Background="#F9F9F9" BorderBrush="#E0E0E0">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal" Margin="4,2">
                                <TextBlock Text="💡" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="Need Help? Click here to view tips on reviewing speakers, json storage rules, and audio playback requirements."
                       FontWeight="SemiBold" Foreground="#1565C0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Expander.Header>

                        <StackPanel Margin="24,12,12,12">
                            <!-- Audio Playback Alert Callout -->
                            <Border Background="#EFFFFA" BorderBrush="#34A853" BorderThickness="4,0,0,0" Padding="10,6" Margin="0,0,0,12">
                                <TextBlock TextWrapping="Wrap" LineHeight="18">
                <Bold Foreground="#2E7D32">🎵 Audio Playback Requirements:</Bold><LineBreak />
                • Only <Span Foreground="#C62828" FontWeight="SemiBold">modded/custom audio files</Span> located inside your <Italic>&lt;GameDir&gt;\override</Italic> subdirectory can be audited directly from this table.<LineBreak />
                • Playback relies on <Bold>ffmpeg/ffplay</Bold>. If ffmpeg is not on your standard path, use the <Italic>ffmpeg path</Italic> option in <Bold>Step 4. Voices and Sound Options</Bold> to specify its full directory path.
                                </TextBlock>
                            </Border>

                            <!-- Technical Action Guides -->
                            <TextBlock TextWrapping="Wrap" LineHeight="18" Foreground="#333333" Margin="0,0,0,12">
            <Bold Foreground="#1565C0">⚙️ Command Bar Actions &amp; File Formats:</Bold><LineBreak />
            • <Bold>Find Speakers:</Bold> Scans your DLG folder (and CRE folder, if set) to figure out which NPC speaks each line and their gender. It writes <Italic>speaker-strrefs.json</Italic> and <Italic>speaker-names.json</Italic> beside your <Italic>dialog.tlk</Italic>. This is completely <Bold>safe to re-run</Bold>—it only appends new names and will never overwrite ones you have already reviewed. Run this again after adding or changing mods.<LineBreak />
            • <Bold>Reload:</Bold> Uses the generated <Italic>speaker-names.json</Italic> directly for gender data and NPC assignments instead of spending time re-scanning the heavy DLG and CRE files from scratch.<LineBreak />
            • <Bold>Bulk Selection Buttons:</Bold> Use these to manage wide-scale selections based on your active filters:<LineBreak />
              &#160;&#160;• <Bold>Select Filtered:</Bold> Instantly selects every row currently passing your active column filters (even if there are thousands of matches).<LineBreak />
              &#160;&#160;• <Bold>Clear Selection:</Bold> Unchecks all checked rows in the entire dataset at once.<LineBreak />
            • <Bold>Save Changes:</Bold> Commits your grid modifications to disk. Gender corrections are saved directly to <Italic>speaker-names.json</Italic>, while text modifications go to <Italic>text-overrides.json</Italic> and are used <Bold>verbatim (with no re-cleaning)</Bold> the next time you trigger a Run.<LineBreak />
            • <Bold>Revert All Text:</Bold> Instantly resets every single row in the current dataset with hand-edited or saved-override text back to its auto-cleaned baseline. <Span Foreground="#C62828" FontWeight="SemiBold">Important:</Span> You must click <Bold>Save Changes</Bold> afterward to persist this bulk reset to your JSON file.
                            </TextBlock>

                            <!-- General Usage Guide -->
                            <TextBlock TextWrapping="Wrap" LineHeight="18" Foreground="#333333">
            <Bold Foreground="#1565C0">📋 Grid Layout &amp; Filtering Hints:</Bold><LineBreak />
            • <Bold>Column Filters:</Bold> Every column can be filtered completely independently, similar to Excel spreadsheet filtering.<LineBreak />
            • <Bold>Row Checkboxes (Target Selections):</Bold> Click the checkboxes in the very first column of the grid to select specific lines. In <Bold>Step 5. Run</Bold>, you can check the <Italic>Only generate the rows checked in Speaker Review</Italic> option to restrict generation/regeneration specifically to these targeted lines instead of processing the entire game.<LineBreak />
            • <Bold>System/In-game Name Filters:</Bold> The column header filter contains a specialized three-state cycle checkbox. Click it to cycle:<LineBreak />
              &#160;&#160;• <Run Background="#EEEEEE"> (Show All) </Run><LineBreak />
              &#160;&#160;• <Run Background="#EEEEEE"> Checked (Only Non-Empty Rows) </Run><LineBreak />
              &#160;&#160;• <Run Background="#EEEEEE"> Unchecked (Only Empty Rows) </Run>.<LineBreak />
            • <Bold>Gender Column &amp; Filter:</Bold> Displays the speaker's gender. These values are initially <Bold>guessed and automatically resolved</Bold> from the raw game data using the DLG and CRE folders you specified in <Bold>Step 1</Bold> when triggering <Italic>Find Speakers</Italic>.
              The grid uses:<LineBreak />
              &#160;&#160;• <Run Background="#EEEEEE"> M </Run> (Male) — triggers the Male Voice in <Bold>Step 4</Bold>.<LineBreak />
              &#160;&#160;• <Run Background="#EEEEEE"> F </Run> (Female) — triggers the Female Voice in <Bold>Step 4</Bold>.<LineBreak />
              &#160;&#160;• <Run Background="#EEEEEE"> [Blank] </Run> (Unspecified) — falls back to the Default/fallback voice in <Bold>Step 4</Bold>.<LineBreak />
              You can manually override this dropdown at any time, and use the column's header dropdown to filter the grid by gender.<LineBreak />
            • <Bold>Override:</Bold> Shows a checked box if a row contains a custom text modification. Use the header dropdown to filter between:<LineBreak />
            • <Bold>Original Text:</Bold> Read-only reference displaying the raw string data straight out of the game's original dialogue database.<LineBreak />
            • <Bold>Cleaned / Spoken Text (and Row Reset):</Bold> This field is fully editable. Use it to fine-tune grammar, fix typos, modify syntax, or insert phonetic spellings/hints to achieve high-quality TTS voice generation output. If a row has been edited, a blue circular <Bold>↩ (Revert)</Bold> button appears on its left margin—clicking it instantly restores only that individual row back to its original auto-cleaned state.
                            </TextBlock>
                        </StackPanel>
                    </Expander>

                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid.Resources>
                            <Style x:Key="CommandGroupBorder" TargetType="Border">
                                <Setter Property="BorderBrush" Value="#D0D0D0" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="Background" Value="#FBFBFB" />
                                <Setter Property="CornerRadius" Value="3" />
                                <Setter Property="Padding" Value="6,4" />
                                <Setter Property="Margin" Value="0,0,8,0" />
                                <Setter Property="VerticalAlignment" Value="Stretch" />
                            </Style>
                        </Grid.Resources>

                        <Border Grid.Column="0" Style="{StaticResource CommandGroupBorder}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,0,15">
                                <Button Content="Find Speakers" Command="{Binding RunSpeakersCommand}"
                                        Background="#2E7D32" Foreground="White" />
                                <Button Content="Reload" Command="{Binding ReloadSpeakerReviewCommand}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CommandGroupBorder}">
                            <StackPanel Orientation="Vertical" VerticalAlignment="Top" HorizontalAlignment="Center">
                                <Button Content="Clear Filters" Command="{Binding ClearFiltersCommand}" HorizontalAlignment="Center" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0">
                                    <TextBlock Text="Showing " Foreground="#666666" FontSize="11" />
                                    <TextBlock Text="{Binding SpeakerRowsView.Count}" FontWeight="Bold" Foreground="#222222" FontSize="11" />
                                    <TextBlock Text=" matching" Foreground="#666666" FontSize="11" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CommandGroupBorder}">
                            <StackPanel Orientation="Vertical" VerticalAlignment="Top" HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Select Filtered" Command="{Binding SelectFilteredCommand}"
                                            ToolTip="Adds every row currently passing the filters to the selection." />
                                    <Button Content="Clear Selection" Command="{Binding ClearSelectionCommand}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding SelectedStrRefCount}" FontWeight="Bold" Foreground="#222222" FontSize="11" />
                                    <TextBlock Text=" rows selected" Foreground="#666666" FontSize="11" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4" Style="{StaticResource CommandGroupBorder}" Margin="0">
                            <StackPanel Orientation="Vertical" VerticalAlignment="Top" HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Revert All Text" Command="{Binding RevertAllTextCommand}"
                                            Background="#C62828" Foreground="White"
                                            ToolTip="Resets every row with edited or saved-override text back to auto-cleaned. Requires Save Changes to persist." />
                                    <Button Content="Save Changes" Command="{Binding SaveSpeakerChangesCommand}"
                                            Background="#1565C0" Foreground="White" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding PendingChangesCount}" FontWeight="Bold" Foreground="#222222" FontSize="11" />
                                    <TextBlock Text=" pending change(s)" Foreground="#666666" FontSize="11" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <DataGrid Grid.Row="2" ItemsSource="{Binding SpeakerRowsView}"
                              CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="False"
                              CanUserSortColumns="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="✓" Width="30">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="StrRef" Width="70" IsReadOnly="True">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="StrRef" FontWeight="Bold" />
                                            <TextBox Text="{Binding DataContext.FilterStrRef, RelativeSource={RelativeSource AncestorType=DataGrid}, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StrRef}" Margin="4,0" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="System name" Width="120" IsReadOnly="True">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <DockPanel LastChildFill="False">
                                                <TextBlock Text="System name" FontWeight="Bold" DockPanel.Dock="Left" VerticalAlignment="Center" />
                                                <CheckBox IsThreeState="True"
                                                    ToolTip="Click to cycle: Dash (Show All) -> Checked (Only Non-Empty) -> Unchecked (Only Empty)"
                                                    IsChecked="{Binding DataContext.FilterSystemNameState, RelativeSource={RelativeSource AncestorType=DataGrid}, Mode=TwoWay}"
                                                    DockPanel.Dock="Right"
                                                    VerticalAlignment="Center"
                                                    Margin="5,0,0,0" />
                                            </DockPanel>
                                            <TextBox Text="{Binding DataContext.FilterSystemName, RelativeSource={RelativeSource AncestorType=DataGrid}, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SystemName}" Margin="4,0" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="In-game name" Width="140" IsReadOnly="True">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <DockPanel LastChildFill="False">
                                                <TextBlock Text="In-game name" FontWeight="Bold" />
                                                <CheckBox IsThreeState="True"
                                                    ToolTip="Click to cycle: Dash (Show All) -> Checked (Only Non-Empty) -> Unchecked (Only Empty)"
                                                    IsChecked="{Binding DataContext.FilterRealNameState, RelativeSource={RelativeSource AncestorType=DataGrid}, Mode=TwoWay}"
                                                    DockPanel.Dock="Right"
                                                    VerticalAlignment="Center"
                                                    Margin="5,0,0,0" />
                                            </DockPanel>
                                            <TextBox Text="{Binding DataContext.FilterRealName, RelativeSource={RelativeSource AncestorType=DataGrid}, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RealName}" Margin="4,0" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Gender" Width="90">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="Gender" FontWeight="Bold" />
                                            <ComboBox ItemsSource="{x:Static vm:MainViewModel.GenderFilterOptions}"
                                                      SelectedItem="{Binding DataContext.FilterGender, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{x:Static vm:MainViewModel.SpeakerGenderOptions}"
                                                  SelectedItem="{Binding Gender, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Voiced" Width="80" IsReadOnly="True">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="Voiced" FontWeight="Bold" />
                                            <ComboBox ItemsSource="{x:Static vm:MainViewModel.VoicedFilterOptions}"
                                                      SelectedItem="{Binding DataContext.FilterVoiced, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding HasSound, Mode=OneWay}" IsHitTestVisible="False"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="SoundResRef" Width="100" IsReadOnly="True">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="SoundFile" FontWeight="Bold" />
                                            <TextBox Text="{Binding DataContext.FilterSoundResRef, RelativeSource={RelativeSource AncestorType=DataGrid}, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding SoundResRef}"
                                                Command="{Binding DataContext.PlaySoundCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding SoundResRef}"
                                                ToolTip="Click to listen to this audio file"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="#1565C0"
                                                Cursor="Hand"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Margin="4,0">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Padding" Value="0" />
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="TextBlock.TextDecorations" Value="Underline" />
                                                            <Setter Property="Foreground" Value="#003399" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Override" Width="60" IsReadOnly="True"
                                                     ToolTipService.ToolTip="Checked if this line already has a saved hand-edited text override.">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="Override" FontWeight="Bold" />
                                            <ComboBox ItemsSource="{x:Static vm:MainViewModel.OverrideFilterOptions}"
                                                      SelectedItem="{Binding DataContext.FilterOverride, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding ShowsOverride, Mode=OneWay}" IsHitTestVisible="False"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Original text" Width="*" IsReadOnly="True">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="Original text" FontWeight="Bold" />
                                            <TextBox Text="{Binding DataContext.FilterText, RelativeSource={RelativeSource AncestorType=DataGrid}, UpdateSourceTrigger=PropertyChanged}"
                                                     ToolTip="Searches both Original text and Cleaned/Spoken text." />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RawText}" Margin="4,0" VerticalAlignment="Center" TextWrapping="Wrap" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Cleaned / spoken text (editable)" Width="*" IsReadOnly="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">

                                            <Button Command="{Binding DataContext.RevertRowTextCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
        CommandParameter="{Binding}"
        Visibility="{Binding ShowsOverride, Converter={StaticResource BoolToVis}}"
        ToolTip="Revert to original text"
        Cursor="Hand"
        Width="20"
        Height="20"
        VerticalAlignment="Center">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="backBorder"
                    Background="#F4F8FC"
                    BorderBrush="#90CAF9"
                    BorderThickness="1"
                    CornerRadius="10">
                                                            <TextBlock x:Name="icon"
                           Text="↩"
                           FontSize="13"
                           Foreground="#1565C0"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="0,-1,0,0" />
                                                        </Border>

                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="backBorder" Property="Background" Value="#E3F2FD" />
                                                                <Setter TargetName="backBorder" Property="BorderBrush" Value="#42A5F5" />
                                                                <Setter TargetName="icon" Property="Foreground" Value="#0D47A1" />
                                                            </Trigger>

                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="backBorder" Property="Background" Value="#BBDEFB" />
                                                                <Setter TargetName="backBorder" Property="BorderBrush" Value="#1E88E5" />
                                                                <Setter Property="RenderTransform">
                                                                    <Setter.Value>
                                                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95" />
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <TextBlock Text="{Binding CleanedText, Mode=OneWay}"
                                                       Margin="4,2"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>

                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding CleanedText, UpdateSourceTrigger=PropertyChanged}"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="False"
                                                 VerticalContentAlignment="Top"
                                                 Margin="0" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Step 4: Sound Options -->
            <TabItem Header="4. Voices and Sound Options">
                <StackPanel Margin="10">
                    <GroupBox Header="Voices">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="Default / fallback" />
                            <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding AvailableVoices}"
                                      SelectedItem="{Binding SelectedVoice}"
                                      ToolTip="Used when gender can't be resolved for a line." />
                            <Button Grid.Row="0" Grid.Column="2" Content="🔊 Preview" Command="{Binding PreviewVoiceCommand}" CommandParameter="{Binding SelectedVoice}" />
                            <Button Grid.Row="0" Grid.Column="3" Content="Refresh voices" Command="{Binding RefreshVoicesCommand}" />

                            <Label Grid.Row="1" Grid.Column="0" Content="Male voice" />
                            <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding AvailableVoices}"
                                      SelectedItem="{Binding SelectedMaleVoice}" />
                            <Button Grid.Row="1" Grid.Column="2" Content="🔊 Preview" Command="{Binding PreviewVoiceCommand}" CommandParameter="{Binding SelectedMaleVoice}" />

                            <Label Grid.Row="2" Grid.Column="0" Content="Female voice" />
                            <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding AvailableVoices}"
                                      SelectedItem="{Binding SelectedFemaleVoice}" />
                            <Button Grid.Row="2" Grid.Column="2" Content="🔊 Preview" Command="{Binding PreviewVoiceCommand}" CommandParameter="{Binding SelectedFemaleVoice}" />

                            <Label Grid.Row="3" Grid.Column="0" Content="Preview text" />
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding PreviewText, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Row="3" Grid.Column="2" Content="Stop" Command="{Binding StopPreviewCommand}" />
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Output options">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="60" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <CheckBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Content="Convert to Ogg Vorbis (needs ffmpeg)"
                                      IsChecked="{Binding UseOgg}" />

                            <Label Grid.Row="1" Grid.Column="0" Content="ffmpeg path" />
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding FfmpegPath, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding UseOgg}"
                                     ToolTip="Leave as 'ffmpeg' if it's on PATH (e.g. installed via 'winget install Gyan.FFmpeg')." />

                            <Label Grid.Row="2" Grid.Column="0" Content="Ogg quality (0-10)" />
                            <Slider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="10" Value="{Binding OggQuality}"
                                    IsEnabled="{Binding UseOgg}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding OggQuality}" VerticalAlignment="Center" />

                            <Label Grid.Row="3" Grid.Column="0" Content="Speech rate" />
                            <Slider Grid.Row="3" Grid.Column="1" Minimum="-10" Maximum="10" Value="{Binding Rate}"
                                    TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding Rate}" VerticalAlignment="Center" />

                            <Label Grid.Row="4" Grid.Column="0" Content="Volume" />
                            <Slider Grid.Row="4" Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding Volume}"
                                    TickFrequency="10" IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding Volume}" VerticalAlignment="Center" />

                            <Label Grid.Row="5" Grid.Column="0" Content="Resref prefix" />
                            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Prefix, UpdateSourceTrigger=PropertyChanged}"
                                     HorizontalAlignment="Left" Width="60" MaxLength="2" />
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </TabItem>

            <!-- Step 5: Run -->
            <TabItem Header="5. Run">
                <StackPanel Margin="10">
                    <GroupBox Header="Testing">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="Limit (lines)" />
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding LimitText, UpdateSourceTrigger=PropertyChanged}"
                                     HorizontalAlignment="Left" Width="100"
                                     ToolTip="Leave blank to process every unvoiced line. Set a small number (e.g. 10-20) to sample a few first." />

                            <CheckBox Grid.Row="1" Grid.Column="1" Content="Dry run (write WAV/OGG files only — don't touch dialog.tlk or the manifest)"
                                      IsChecked="{Binding DryRun}" />
                        </Grid>
                    </GroupBox>

                    <CheckBox Content="Only generate the rows checked in Speaker Review" IsChecked="{Binding GenerateSelectedOnly}" />
                    <TextBlock Text="{Binding SelectedStrRefCount, StringFormat='({0} line(s) currently selected)'}" Foreground="Gray" Margin="20,0,0,4" />

                    <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="4,4,4,0"
                               Text="Click Run (bottom right) to generate audio for every unvoiced, speaker-known line and patch dialog.tlk, then write dialog-report.csv. If you skipped finding speakers in step 3, this will fall back to a live DLG/CRE scan automatically." />
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- ===================== Wizard navigation + Run/Cancel ===================== -->
        <Grid Grid.Row="1" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="&lt; Back" Command="{Binding PreviousStepCommand}" Width="90" />
                <Button Content="Next &gt;" Command="{Binding NextStepCommand}" Width="90" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="Run" Command="{Binding RunCommand}" Width="100" FontWeight="Bold"
                        Background="#2E7D32" Foreground="White" />
                <Button Content="Cancel" Command="{Binding CancelCommand}" Width="100" />
            </StackPanel>
        </Grid>

        <!-- ===================== Progress ===================== -->
        <Grid Grid.Row="2" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ProgressBar Grid.Column="0" Height="20" Minimum="0" Maximum="{Binding ProgressMax}"
                         Value="{Binding ProgressValue, Mode=OneWay}"
                         IsIndeterminate="{Binding IsProgressIndeterminate}" />
            <TextBlock Grid.Column="1" Text="{Binding StatusText}" Margin="8,0,0,0" VerticalAlignment="Center" />
        </Grid>

        <!-- ===================== Log ===================== -->
        <Border Grid.Row="3" BorderBrush="Gray" BorderThickness="1">
            <ListBox x:Name="LogListBox" ItemsSource="{Binding LogLines}"
                     FontFamily="Consolas" FontSize="12"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto" />
        </Border>
    </Grid>
</Window>