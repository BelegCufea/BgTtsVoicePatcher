<Window x:Class="BgTtsVoicePatcher.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BgTtsVoicePatcher.Gui.ViewModels"
        Title="BgTtsVoicePatcher" Height="880" Width="1050" MinHeight="700" MinWidth="900">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="4,2" />
            <Setter Property="Padding" Value="3" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="4,2" />
            <Setter Property="Padding" Value="3" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="4,2" />
            <Setter Property="Padding" Value="10,4" />
        </Style>
        <Style TargetType="Label">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="4,4" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="Expander">
            <Setter Property="Margin" Value="0,4" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Margin" Value="4" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="True" />
            <Setter Property="CanUserDeleteRows" Value="True" />
            <Setter Property="RowHeaderWidth" Value="0" />
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="180" />
        </Grid.RowDefinitions>

        <!-- ===================== Wizard tabs ===================== -->
        <TabControl Grid.Row="0" SelectedIndex="{Binding CurrentStepIndex}" Margin="0,0,0,8">

            <!-- Step 1: Game, TLK, DLG and CRE -->
            <TabItem Header="1. Directories">
                <StackPanel Margin="10">
                    <GroupBox Header="Game directory">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="Game directory" />
                            <TextBox Grid.Column="1" Text="{Binding GameDir, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Root of your game install, containing 'override' and 'lang' folders." />
                            <Button Grid.Column="2" Content="Browse..." Command="{Binding BrowseGameDirCommand}" />
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="dialog.tlk">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Content="Found TLK files" />
                                <ComboBox Grid.Column="1" ItemsSource="{Binding DiscoveredTlkFiles}"
                                          SelectedItem="{Binding SelectedTlkPath}" />
                                <Button Grid.Column="2" Content="Rescan" Command="{Binding ScanForTlkCommand}" />
                                <Button Grid.Column="3" Content="Browse manually..." Command="{Binding BrowseTlkCommand}" />
                            </Grid>
                            <TextBlock Margin="4,8,4,0" TextWrapping="Wrap" Foreground="Gray"
                                       Text="Scans '&lt;game-dir&gt;\lang\*\dialog.tlk' automatically after you pick a game directory. If your install uses a non-standard layout, use Browse manually." />
                        </StackPanel>
                    </GroupBox>

                                        <GroupBox Header="Speaker / gender resolution (recommended: Near Infinity mass-export)">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="DLG folder" />
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding DlgDir, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Optional. Near Infinity mass-export of .dlg files. Defaults to the override folder." />
                            <Button Grid.Row="0" Grid.Column="2" Content="Browse..." Command="{Binding BrowseDlgDirCommand}" />

                            <Label Grid.Row="1" Grid.Column="0" Content="CRE folder" />
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CreDir, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Optional. Near Infinity mass-export of .cre files. Enables automatic male/female detection." />
                            <Button Grid.Row="1" Grid.Column="2" Content="Browse..." Command="{Binding BrowseCreDirCommand}" />

                            <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" TextWrapping="Wrap" Foreground="Gray" Margin="4,4,4,0"
                                       Text="Tip: In Near Infinity, press Ctrl+M (Tools -&gt; Mass Export), select DLG (and separately CRE), uncheck 'Decompile scripts and dialogs', and export each to its own folder." />
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Encoding">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="Encoding" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableEncodings}"
                                      SelectedItem="{Binding SelectedEncoding}"
                                      DisplayMemberPath="DisplayName">
                            </ComboBox>
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </TabItem>

            <!-- Step 2: Config -->
            <TabItem Header="2. Config">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <GroupBox Header="patcher-config.json">
                            <StackPanel>
                                <TextBlock Text="{Binding ConfigStatusText}" TextWrapping="Wrap" Foreground="Gray" Margin="4,0,4,6" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Label Grid.Column="0" Content="Config file" />
                                    <TextBox Grid.Column="1" Text="{Binding ConfigPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" />
                                    <Button Grid.Column="2" Content="Browse..." Command="{Binding BrowseConfigCommand}" />
                                    <Button Grid.Column="3" Content="Reload" Command="{Binding ReloadConfigCommand}" />
                                </Grid>

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Label Grid.Row="0" Grid.Column="0" Content="PC name" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding PcName, UpdateSourceTrigger=PropertyChanged}"
                                             HorizontalAlignment="Left" Width="200"
                                             ToolTip="Replaces &lt;CHARNAME&gt; and &lt;GABBER&gt; tokens in dialogue." />

                                    <Label Grid.Row="1" Grid.Column="0" Content="PC race" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding PcRace, UpdateSourceTrigger=PropertyChanged}"
                                             HorizontalAlignment="Left" Width="200"
                                             ToolTip="Replaces &lt;RACE&gt; and &lt;PRO_RACE&gt; tokens." />

                                    <Label Grid.Row="2" Grid.Column="0" Content="PC gender" />
                                    <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding PcGenderOptions}"
                                              SelectedItem="{Binding PcGender}" HorizontalAlignment="Left" Width="200"
                                              ToolTip="Which side of gender-sensitive tokens (&lt;PRO_HESHE&gt; etc.) is used." />
                                </Grid>

                                <Button Content="Save Config" Command="{Binding SaveConfigCommand}" HorizontalAlignment="Left" Margin="4,10,4,4"
                                        Background="#1565C0" Foreground="White" />
                            </StackPanel>
                        </GroupBox>

                        <Expander Header="CRE name replacements (DLG system name -&gt; CRE basename)">
                            <DataGrid ItemsSource="{Binding CreNameReplacementsRows}" MaxHeight="220">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="DLG system name" Binding="{Binding Key}" Width="*" />
                                    <DataGridTextColumn Header="CRE basename" Binding="{Binding Value}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Expander>

                        <Expander Header="Gender overrides (system name -&gt; forced gender)">
                            <DataGrid ItemsSource="{Binding GenderOverridesRows}" MaxHeight="220">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="System name" Binding="{Binding Key}" Width="*" />
                                    <DataGridComboBoxColumn Header="Gender" SelectedItemBinding="{Binding Value}"
                                                             ItemsSource="{x:Static vm:MainViewModel.SpeakerGenderOptions}"
                                                             Width="100" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Expander>

                        <Expander Header="Gender tokens (male / female / neutral replacement words)">
                            <DataGrid ItemsSource="{Binding GenderTokenRows}" MaxHeight="260">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Token" Binding="{Binding Token}" Width="*" />
                                    <DataGridTextColumn Header="Male" Binding="{Binding Male}" Width="*" />
                                    <DataGridTextColumn Header="Female" Binding="{Binding Female}" Width="*" />
                                    <DataGridTextColumn Header="Neutral" Binding="{Binding Neutral}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Expander>

                        <Expander Header="Identity tokens (replaced by PC name/race)">
                            <DataGrid ItemsSource="{Binding IdentityTokenRows}" MaxHeight="180">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Token" Binding="{Binding Value}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Expander>

                        <Expander Header="Phonetic rules (regex find/replace, applied last)">
                            <DataGrid ItemsSource="{Binding PhoneticRuleRows}" MaxHeight="220">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Pattern (regex)" Binding="{Binding Pattern}" Width="*" />
                                    <DataGridTextColumn Header="Replacement" Binding="{Binding Replacement}" Width="*" />
                                    <DataGridTextColumn Header="Comment" Binding="{Binding Comment}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Step 3: Speaker Review -->
            <TabItem Header="3. Speaker Review">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,6">
                        <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="4,0,4,6"
                               Text="Filter each column independently, like Excel. Edit Gender or Cleaned Text and click Save Changes - gender corrections go to speaker-names.json, text edits go to text-overrides.json and are used verbatim (no re-cleaning) the next time you Run." />
                        <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="4,0,4,6"
                               Text="Find Speakers scans your DLG folder (and CRE folder, if set) to figure out which NPC speaks each line and their gender, writing speaker-strrefs.json and speaker-names.json beside dialog.tlk. Safe to re-run - it only adds new names, never overwrites ones you've already reviewed. You should run it after any mod changes." />
                        <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="4,0,4,6"
                               Text="You can use Reload to use the generated speaker-names.json for gender and NPC names instead of scanning the DLG and CRE files again." />
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button Content="Find Speakers" Command="{Binding RunSpeakersCommand}"
                                    Background="#2E7D32" Foreground="White" />
                            <Button Content="Reload" Command="{Binding ReloadSpeakerReviewCommand}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Clear Filters" Command="{Binding ClearFiltersCommand}" />
                            <Button Content="Save Changes" Command="{Binding SaveSpeakerChangesCommand}"
                                    Background="#1565C0" Foreground="White" />
                        </StackPanel>
                    </Grid>

                    <DataGrid Grid.Row="2" ItemsSource="{Binding SpeakerRowsView}"
                              CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="False"
                              CanUserSortColumns="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="StrRef" Width="70">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="StrRef" FontWeight="Bold" />
                                            <TextBox Text="{Binding DataContext.FilterStrRef, RelativeSource={RelativeSource AncestorType=DataGrid}, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StrRef}" Margin="4,0" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="System name" Width="120">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="System name" FontWeight="Bold" />
                                            <TextBox Text="{Binding DataContext.FilterSystemName, RelativeSource={RelativeSource AncestorType=DataGrid}, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SystemName}" Margin="4,0" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="In-game name" Width="140">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="In-game name" FontWeight="Bold" />
                                            <TextBox Text="{Binding DataContext.FilterRealName, RelativeSource={RelativeSource AncestorType=DataGrid}, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RealName}" Margin="4,0" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Gender" Width="90">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="Gender" FontWeight="Bold" />
                                            <ComboBox ItemsSource="{x:Static vm:MainViewModel.GenderFilterOptions}"
                                                      SelectedItem="{Binding DataContext.FilterGender, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{x:Static vm:MainViewModel.SpeakerGenderOptions}"
                                                  SelectedItem="{Binding Gender, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Voiced" Width="80">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="Voiced" FontWeight="Bold" />
                                            <ComboBox ItemsSource="{x:Static vm:MainViewModel.VoicedFilterOptions}"
                                                      SelectedItem="{Binding DataContext.FilterVoiced, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding HasSound, Mode=OneWay}" IsHitTestVisible="False"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="SoundResRef" Binding="{Binding SoundResRef}" Width="100" IsReadOnly="True" />

                            <DataGridCheckBoxColumn Header="Override" Binding="{Binding IsTextOverridden, Mode=OneWay}" Width="60" IsReadOnly="True"
                                                     ToolTipService.ToolTip="Checked if this line already has a saved hand-edited text override." />

                            <DataGridTemplateColumn Header="Original text" Width="*">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="Original text" FontWeight="Bold" />
                                            <TextBox Text="{Binding DataContext.FilterText, RelativeSource={RelativeSource AncestorType=DataGrid}, UpdateSourceTrigger=PropertyChanged}"
                                                     ToolTip="Searches both Original text and Cleaned/Spoken text." />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RawText}" Margin="4,0" VerticalAlignment="Center" TextWrapping="Wrap" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Cleaned / spoken text (editable)" Binding="{Binding CleanedText, UpdateSourceTrigger=PropertyChanged}" Width="*" IsReadOnly="False" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Step 4: Sound Options -->
            <TabItem Header="4. Voices and Sound Options">
                <StackPanel Margin="10">
                    <GroupBox Header="Voices">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="Default / fallback" />
                            <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding AvailableVoices}"
                                      SelectedItem="{Binding SelectedVoice}"
                                      ToolTip="Used when gender can't be resolved for a line." />
                            <Button Grid.Row="0" Grid.Column="2" Content="Refresh voices" Command="{Binding RefreshVoicesCommand}" />

                            <Label Grid.Row="1" Grid.Column="0" Content="Male voice" />
                            <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding AvailableVoices}"
                                      SelectedItem="{Binding SelectedMaleVoice}" />

                            <Label Grid.Row="2" Grid.Column="0" Content="Female voice" />
                            <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding AvailableVoices}"
                                      SelectedItem="{Binding SelectedFemaleVoice}" />
                        </Grid>
                    </GroupBox>


                    <GroupBox Header="Output options">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="60" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <CheckBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Content="Convert to Ogg Vorbis (needs ffmpeg)"
                                      IsChecked="{Binding UseOgg}" />

                            <Label Grid.Row="1" Grid.Column="0" Content="ffmpeg path" />
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding FfmpegPath, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding UseOgg}"
                                     ToolTip="Leave as 'ffmpeg' if it's on PATH (e.g. installed via 'winget install Gyan.FFmpeg')." />

                            <Label Grid.Row="2" Grid.Column="0" Content="Ogg quality (0-10)" />
                            <Slider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="10" Value="{Binding OggQuality}"
                                    IsEnabled="{Binding UseOgg}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding OggQuality}" VerticalAlignment="Center" />

                            <Label Grid.Row="3" Grid.Column="0" Content="Speech rate" />
                            <Slider Grid.Row="3" Grid.Column="1" Minimum="-10" Maximum="10" Value="{Binding Rate}"
                                    TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding Rate}" VerticalAlignment="Center" />

                            <Label Grid.Row="4" Grid.Column="0" Content="Volume" />
                            <Slider Grid.Row="4" Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding Volume}"
                                    TickFrequency="10" IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding Volume}" VerticalAlignment="Center" />

                            <Label Grid.Row="5" Grid.Column="0" Content="Resref prefix" />
                            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Prefix, UpdateSourceTrigger=PropertyChanged}"
                                     HorizontalAlignment="Left" Width="60" MaxLength="2" />
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </TabItem>

            <!-- Step 5: Run -->
            <TabItem Header="5. Run">
                <StackPanel Margin="10">
                    <GroupBox Header="Testing">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="Limit (lines)" />
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding LimitText, UpdateSourceTrigger=PropertyChanged}"
                                     HorizontalAlignment="Left" Width="100"
                                     ToolTip="Leave blank to process every unvoiced line. Set a small number (e.g. 10-20) to sample a few first." />

                            <CheckBox Grid.Row="1" Grid.Column="1" Content="Dry run (write WAV/OGG files only — don't touch dialog.tlk or the manifest)"
                                      IsChecked="{Binding DryRun}" />
                        </Grid>
                    </GroupBox>

                    <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="4,4,4,0"
                               Text="Click Run (bottom right) to generate audio for every unvoiced, speaker-known line and patch dialog.tlk, then write dialog-report.csv. If you skipped finding speakers in step 3, this will fall back to a live DLG/CRE scan automatically." />
                </StackPanel>
            </TabItem>

        </TabControl>

        <!-- ===================== Wizard navigation + Run/Cancel ===================== -->
        <Grid Grid.Row="1" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="&lt; Back" Command="{Binding PreviousStepCommand}" Width="90" />
                <Button Content="Next &gt;" Command="{Binding NextStepCommand}" Width="90" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="Run" Command="{Binding RunCommand}" Width="100" FontWeight="Bold"
                        Background="#2E7D32" Foreground="White" />
                <Button Content="Cancel" Command="{Binding CancelCommand}" Width="100" />
            </StackPanel>
        </Grid>

        <!-- ===================== Progress ===================== -->
        <Grid Grid.Row="2" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ProgressBar Grid.Column="0" Height="20" Minimum="0" Maximum="{Binding ProgressMax}"
                         Value="{Binding ProgressValue, Mode=OneWay}"
                         IsIndeterminate="{Binding IsProgressIndeterminate}" />
            <TextBlock Grid.Column="1" Text="{Binding StatusText}" Margin="8,0,0,0" VerticalAlignment="Center" />
        </Grid>

        <!-- ===================== Log ===================== -->
        <Border Grid.Row="3" BorderBrush="Gray" BorderThickness="1">
            <ListBox x:Name="LogListBox" ItemsSource="{Binding LogLines}"
                     FontFamily="Consolas" FontSize="12"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto" />
        </Border>
    </Grid>
</Window>
